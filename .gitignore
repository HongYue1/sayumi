# Compiled binary
/Reader
/Reader.exe
/sayumi
/sayumi.exe

# Portable runtime data (created next to the binary at runtime).
# Note: only the runtime /Fonts/ is ignored; the tracked source for the drop-in
# fonts that releases bundle lives in /fonts-bundle/ (intentionally committed).
/Library/
/Fonts/

# Frontend dependencies & caches
/frontend/node_modules/
/frontend/.vite/

# Embedded frontend build output (generated by `vite build`; .gitkeep retained
# so the //go:embed dist directive always has a directory to embed).
/cmd/sayumi/dist/*
!/cmd/sayumi/dist/.gitkeep

# OS / editor cruft
.DS_Store
*.swp

# Cross-compiled release artifacts (release.sh)
/dist-release/

# Personal Claude Code settings (per-user, not shared)
/.claude/settings.local.json

# Local skills / Claude Code tooling (per-user, not part of the project)
/.claude/
/.agents/
/skills-lock.json
